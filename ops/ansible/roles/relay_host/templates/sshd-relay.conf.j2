# Managed by Ansible. Port 22 remains available for the administrator.
Port {{ relay_host_admin_ssh_port }}
Port {{ relay_host_ssh_port }}
GatewayPorts no
AuthorizedKeysCommand {{ relay_host_root }}/authorized-keys.sh %u
AuthorizedKeysCommandUser cag-authkeys

Match LocalPort {{ relay_host_admin_ssh_port }}
    AllowUsers {{ admin_user }}

Match LocalPort {{ relay_host_ssh_port }}
    AllowUsers cag-device cag-client cag-enroll cag-pair cag-control

Match all

Match User cag-device
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    PubkeyAuthentication yes
    AllowTcpForwarding remote
    AllowStreamLocalForwarding no
    PermitListen 127.0.0.1:*
    PermitTTY no
    X11Forwarding no
    AllowAgentForwarding no
    PermitTunnel no
    PermitUserRC no
    ForceCommand /bin/false

Match User cag-client
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    PubkeyAuthentication yes
    AllowTcpForwarding local
    AllowStreamLocalForwarding no
    PermitOpen 127.0.0.1:*
    PermitTTY no
    X11Forwarding no
    AllowAgentForwarding no
    PermitTunnel no
    PermitUserRC no
    ForceCommand /bin/false

Match User cag-enroll
    PasswordAuthentication {{ 'yes' if relay_host_enrollment_enabled else 'no' }}
    KbdInteractiveAuthentication no
    PubkeyAuthentication no
    AllowTcpForwarding no
    AllowStreamLocalForwarding no
    PermitTTY no
    X11Forwarding no
    AllowAgentForwarding no
    PermitTunnel no
    PermitUserRC no
{% if relay_host_enrollment_enabled %}
    AuthenticationMethods password
    ForceCommand {{ relay_host_root }}/enroll.sh
{% else %}
    ForceCommand /bin/false
{% endif %}

Match User cag-pair
    PasswordAuthentication yes
    KbdInteractiveAuthentication no
    PubkeyAuthentication no
    AuthenticationMethods password
    AllowTcpForwarding no
    AllowStreamLocalForwarding no
    PermitTTY no
    X11Forwarding no
    AllowAgentForwarding no
    PermitTunnel no
    PermitUserRC no
    ForceCommand {{ relay_host_root }}/pair-client.sh

Match User cag-control
    PasswordAuthentication no
    KbdInteractiveAuthentication no
    PubkeyAuthentication yes
    AllowTcpForwarding no
    AllowStreamLocalForwarding no
    PermitTTY no
    X11Forwarding no
    AllowAgentForwarding no
    PermitTunnel no
    PermitUserRC no

Match all
