<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <queries>
        <package android:name="com.byd.dishare" />
        <package android:name="com.vk.vkvideo" />
        <package android:name="ru.rutube.app" />
        <package android:name="ru.yandex.yandexnavi" />
        <package android:name="ru.yandex.music" />
        <package android:name="com.tencent.qqlive.audiobox" />
        <package android:name="com.mgtv.auto" />
        <package android:name="cn.cmvideo.car.play" />
        <package android:name="com.youku.car" />
        <package android:name="com.tencent.qqlive" />
        <package android:name="com.qiyi.video.pad" />
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_denza_apps"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_denza_apps"
        android:theme="@style/DenzaAppsTheme">
        <service
            android:name=".SourceKeeperService"
            android:exported="true" />
        <service
            android:name=".SimulcastAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/simulcast_a11y_service" />
        </service>
        <service
            android:name=".SimulcastOverlayService"
            android:exported="true">
            <intent-filter>
                <action android:name="dev.denza.apps.SHOW_SIMULCAST_OVERLAY" />
                <action android:name="dev.denza.apps.ARM_SIMULCAST_APP_CHANGE" />
                <action android:name="dev.denza.apps.HIDE_SIMULCAST_OVERLAY" />
                <action android:name="dev.denza.apps.START_SIMULCAST_TARGET" />
                <action android:name="dev.denza.apps.STOP_SIMULCAST_TARGET" />
            </intent-filter>
        </service>

        <receiver
            android:name=".SimulcastBootReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="action.byd.dishare.DIALOG_HOME" />
                <action android:name="action.byd.dishare.DIALOG_LAUNCHER" />
                <action android:name="action.byd.dishare.DIALOG_CLOSE" />
                <action android:name="dev.denza.apps.SHOW_SIMULCAST_OVERLAY" />
                <action android:name="dev.denza.apps.ARM_SIMULCAST_APP_CHANGE" />
                <action android:name="dev.denza.apps.HIDE_SIMULCAST_OVERLAY" />
                <action android:name="dev.denza.apps.START_SIMULCAST_TARGET" />
                <action android:name="dev.denza.apps.STOP_SIMULCAST_TARGET" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".AppPickerActivity"
            android:exported="false"
            android:label="Приложения для трансляции" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
