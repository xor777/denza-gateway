<?xml version="1.0" encoding="utf-8"?>
<!-- Fast-switch guard: window-state events only, zero notification timeout.
     A separate service from the Simulcast one so the guard reacts within the
     ~95 ms vendor crash budget without unbatching the content-changed flood
     the Simulcast overlay subscribes to. -->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="0"
    android:description="@string/mirror_guard_a11y_desc" />
